rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'createdAt'])
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'createdAt'])
        && data.text is string && data.text.size() <= 10000
        && data.sender in ['user', 'ai']
        && data.createdAt == request.time;
    }

    // Resource Logic
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email;
    }

    match /users/{userId}/chats/{chatId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(chatId) && isValidChat(incoming());
      allow update: if isOwner(userId) && isValidChat(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId);

      match /messages/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(messageId) && isValidMessage(incoming());
      }
    }
  }
}
